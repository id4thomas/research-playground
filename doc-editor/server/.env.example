# LLM (OpenAI-compatible endpoint)
LLM__BASE_URL=http://localhost:901/v1
LLM__API_KEY=EMPTY
LLM__MODEL=Qwen3.6-35B-A3B

# MLflow tracing
# ENABLED=false면 mlflow URI/autolog 호출을 모두 스킵 (서버 없이도 기동 가능).
TRACING__ENABLED=true
TRACING__URI=http://localhost:7000
TRACING__EXPERIMENT=2605-doc-editor

# Logging
LOGGING__LOG_LEVEL=info
LOGGING__FORMAT=console
